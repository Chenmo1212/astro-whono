---
// EncryptedPostClient component - Client-side decryption with password verification
interface Props {
	postId: string;
	encryptedContent: {
		encrypted: string;
		salt: string;
		iv: string;
		authTag: string;
		algorithm?: string;
		iterations?: number;
	};
}

const { postId, encryptedContent } = Astro.props;

// Get API base URL from environment variable (for separate API server)
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || '';
---

<div id="encrypted-content" class="encrypted-wrapper" data-encrypted-content={JSON.stringify(encryptedContent)}>
	<div class="password-prompt">
		<div class="password-prompt__header">
			<div class="password-prompt__lock">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
					<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
				</svg>
			</div>
			<div class="password-prompt__copy">
				<h2 class="password-prompt__title">加密内容</h2>
				<p class="password-prompt__hint">此文章受密码保护，请输入密码以继续阅读</p>
			</div>
		</div>
		<form id="password-form" class="password-form">
			<label class="password-field">
				<span class="password-field__label">
					<span class="password-field__label-main">密码</span>
					<span class="password-field__label-hint">（区分大小写）</span>
				</span>
				<input
					type="password"
					id="password-input"
					class="password-field__input"
					placeholder="输入密码"
					autocomplete="off"
					required
					aria-describedby="error-message"
				/>
			</label>
			<button type="submit" class="password-form__submit">解锁</button>
		</form>
		<div id="error-message" class="password-message password-message--error" style="display: none;" role="alert">
			<span class="password-message__dot"></span>
			密码错误，请重试
		</div>
		<div id="loading-message" class="password-message password-message--loading" style="display: none;" aria-live="polite">
			验证并解密中
			<span class="loading-dots">
				<span></span><span></span><span></span>
			</span>
		</div>
		<div class="prompt-note">
			<span class="prompt-note__text">如已忘记密码，请联系作者</span>
			<span class="prompt-note__meta">AES-256 加密</span>
		</div>
	</div>
	<div id="post-content" class="post-content" style="display: none;"></div>
</div>

<style>
	.encrypted-wrapper {
		width: 100%;
		max-width: 560px;
		animation: fadeUp 0.5s ease both;
		margin: 50px 0;
	}

	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.password-prompt__header {
		display: flex;
		align-items: flex-start;
		gap: 20px;
		margin-bottom: 40px;
		padding-bottom: 32px;
		border-bottom: 1px solid var(--border);
	}

	.password-prompt__lock {
		width: 40px;
		height: 40px;
		flex-shrink: 0;
		margin-top: 3px;
	}

	.password-prompt__lock svg {
		width: 40px;
		height: 40px;
		stroke: var(--faint);
		color: var(--faint);
	}

	.password-prompt__copy {
		flex: 1;
		min-width: 0;
	}

	.password-prompt__title {
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
		font-size: 22px;
		font-weight: 500;
		letter-spacing: 0.02em;
		margin: 0 0 6px 0;
		color: var(--text);
		line-height: 1.4;
	}

	.password-prompt__hint {
		font-family: Georgia, serif;
		font-style: italic;
		font-size: 14px;
		color: var(--muted);
		margin: 0;
		line-height: 1.6;
	}

	.password-form {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.password-field {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.password-field__label {
		display: flex;
		align-items: baseline;
		gap: 8px;
	}

	.password-field__label-main {
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
		font-size: 13px;
		color: var(--text);
		letter-spacing: 0.05em;
	}

	.password-field__label-hint {
		font-size: 12px;
		color: var(--muted);
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
	}

	.password-field__input {
		width: 100%;
		padding: 11px 14px;
		border: 1px solid var(--border);
		border-radius: 3px;
		background: var(--bg);
		font-family: Georgia, serif;
		font-size: 15px;
		color: var(--text);
		outline: none;
		transition: border-color 0.2s, box-shadow 0.2s;
		letter-spacing: 0.08em;
	}

	.password-field__input::placeholder {
		color: var(--faint);
		letter-spacing: 0.03em;
		font-style: italic;
	}

	.password-field__input:focus {
		border-color: var(--muted);
		box-shadow: 0 0 0 3px rgba(87, 83, 78, 0.06);
	}

	.password-field__input.error {
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.08);
	}

	.password-form__submit {
		align-self: flex-start;
		padding: 9px 28px;
		background: var(--text);
		color: var(--bg);
		border: none;
		border-radius: 3px;
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
		font-size: 13px;
		letter-spacing: 0.08em;
		cursor: pointer;
		transition: background 0.18s, transform 0.1s;
	}

	.password-form__submit:hover {
		background: var(--muted);
	}

	.password-form__submit:active {
		transform: scale(0.98);
	}

	.password-form__submit:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.password-message {
		margin-top: 16px;
		font-size: 13px;
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
		display: flex;
		align-items: center;
		gap: 8px;
		animation: fadeIn 0.25s ease;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.password-message--error {
		color: var(--accent);
	}

	.password-message--loading {
		color: var(--muted);
	}

	.password-message__dot {
		display: inline-block;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--accent);
		flex-shrink: 0;
	}

	.loading-dots {
		display: inline-flex;
		gap: 3px;
		align-items: center;
	}

	.loading-dots span {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--muted);
		animation: dot 1.2s ease-in-out infinite;
	}

	.loading-dots span:nth-child(2) {
		animation-delay: 0.2s;
	}

	.loading-dots span:nth-child(3) {
		animation-delay: 0.4s;
	}

	@keyframes dot {
		0%,
		80%,
		100% {
			transform: scale(0.6);
			opacity: 0.4;
		}
		40% {
			transform: scale(1);
			opacity: 1;
		}
	}

	.prompt-note {
		margin-top: 36px;
		padding-top: 28px;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 12px;
	}

	.prompt-note__text {
		font-size: 12px;
		color: var(--muted);
		font-family: Georgia, serif;
		font-style: italic;
	}

	.prompt-note__meta {
		font-size: 11px;
		color: var(--faint);
		font-family: "Noto Serif SC", ui-serif, Georgia, serif;
		letter-spacing: 0.05em;
	}

	.post-content {
		animation: fadeUp 0.4s ease both;
	}

	@media (max-width: 600px) {
		.encrypted-wrapper {
			padding: 0 1rem;
		}

		.password-prompt__header {
			gap: 16px;
			margin-bottom: 32px;
			padding-bottom: 24px;
		}

		.password-prompt__lock {
			width: 32px;
			height: 32px;
		}

		.password-prompt__lock svg {
			width: 32px;
			height: 32px;
		}

		.password-prompt__title {
			font-size: 20px;
		}

		.password-prompt__hint {
			font-size: 13px;
		}

		.prompt-note {
			margin-top: 28px;
			padding-top: 20px;
		}
	}
</style>

<script define:vars={{ postId, apiBaseUrl }}>
	const form = document.getElementById('password-form');
	const input = document.getElementById('password-input');
	const submitButton = form.querySelector('button[type="submit"]');
	const errorMessage = document.getElementById('error-message');
	const loadingMessage = document.getElementById('loading-message');
	const promptDiv = document.querySelector('.password-prompt');
	const contentDiv = document.getElementById('post-content');

	// Check if already unlocked in session
	const sessionKey = `post-unlocked-${postId}`;
	const cachedContent = sessionStorage.getItem(sessionKey);
	
	if (cachedContent) {
		promptDiv.style.display = 'none';
		contentDiv.innerHTML = cachedContent;
		contentDiv.style.display = 'block';
	}

	/**
	 * Derive encryption key from password using PBKDF2
	 */
	async function deriveKey(password, salt, iterations) {
		const encoder = new TextEncoder();
		const passwordBuffer = encoder.encode(password);
		const saltBuffer = base64ToBuffer(salt);

		// Import password as key material
		const keyMaterial = await crypto.subtle.importKey(
			'raw',
			passwordBuffer,
			{ name: 'PBKDF2' },
			false,
			['deriveBits', 'deriveKey']
		);

		// Derive key using PBKDF2
		const key = await crypto.subtle.deriveKey(
			{
				name: 'PBKDF2',
				salt: saltBuffer,
				iterations: iterations,
				hash: 'SHA-256'
			},
			keyMaterial,
			{ name: 'AES-GCM', length: 256 },
			false,
			['decrypt']
		);

		return key;
	}

	/**
	 * Decrypt content using AES-GCM
	 */
	async function decryptContent(encryptedData, password) {
		try {
			const key = await deriveKey(
				password,
				encryptedData.salt,
				encryptedData.iterations || 100000
			);

			const encryptedBuffer = base64ToBuffer(encryptedData.encrypted);
			const ivBuffer = base64ToBuffer(encryptedData.iv);
			const authTagBuffer = base64ToBuffer(encryptedData.authTag);

			// Combine encrypted data and auth tag for GCM
			const ciphertext = new Uint8Array(encryptedBuffer.byteLength + authTagBuffer.byteLength);
			ciphertext.set(new Uint8Array(encryptedBuffer), 0);
			ciphertext.set(new Uint8Array(authTagBuffer), encryptedBuffer.byteLength);

			// Decrypt
			const decryptedBuffer = await crypto.subtle.decrypt(
				{
					name: 'AES-GCM',
					iv: ivBuffer,
					tagLength: 128
				},
				key,
				ciphertext
			);

			const decoder = new TextDecoder();
			return decoder.decode(decryptedBuffer);
		} catch (error) {
			console.error('Decryption error:', error);
			throw new Error('Failed to decrypt content');
		}
	}

	/**
	 * Convert base64 string to ArrayBuffer
	 */
	function base64ToBuffer(base64) {
		const binaryString = atob(base64);
		const bytes = new Uint8Array(binaryString.length);
		for (let i = 0; i < binaryString.length; i++) {
			bytes[i] = binaryString.charCodeAt(i);
		}
		return bytes.buffer;
	}

	/**
	 * Simple markdown to HTML converter
	 */
	function markdownToHtml(markdown) {
		let html = markdown;
		
		// Headers
		html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
		html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
		html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
		
		// Bold
		html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
		
		// Italic
		html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
		
		// Links
		html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
		
		// Line breaks
		html = html.replace(/\n\n/g, '</p><p>');
		html = html.replace(/\n/g, '<br>');
		
		// Wrap in paragraphs
		html = '<p>' + html + '</p>';
		
		return html;
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const password = input.value;

		// Show loading
		errorMessage.style.display = 'none';
		loadingMessage.style.display = 'block';
		submitButton.disabled = true;

		try {
			// Call server API to verify password
			// Use apiBaseUrl if configured, otherwise use relative URL
			const apiUrl = apiBaseUrl ? `${apiBaseUrl}/api/v1/blog/verify` : '/api/v1/blog/verify';
			const response = await fetch(apiUrl, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ postId, password }),
			});

			const data = await response.json();

			if (data.success) {
				// Password verified! Now get encrypted data from page and decrypt on client side
				try {
					// Get encrypted data from the wrapper element
					const wrapper = document.getElementById('encrypted-content');
					if (!wrapper) {
						throw new Error('Encrypted content wrapper not found');
					}
					
					const encryptedDataStr = wrapper.getAttribute('data-encrypted-content');
					if (!encryptedDataStr) {
						throw new Error('Encrypted content data not found');
					}
					
					const encryptedData = JSON.parse(encryptedDataStr);
					const decryptedContent = await decryptContent(encryptedData, password);
					
					// Success! Render the content
					loadingMessage.style.display = 'none';
					promptDiv.style.display = 'none';
					
					// Convert markdown to HTML
					const htmlContent = markdownToHtml(decryptedContent);
					contentDiv.innerHTML = `<div class="markdown-content">${htmlContent}</div>`;
					contentDiv.style.display = 'block';
					
					// Store in session
					sessionStorage.setItem(sessionKey, contentDiv.innerHTML);
				} catch (decryptError) {
					console.error('Decryption error:', decryptError);
					showError('解密失败，请重试');
				}
			} else {
				// Wrong password
				showError(data.error || '密码错误，请重试');
			}
		} catch (error) {
			console.error('API error:', error);
			showError('验证失败，请重试');
		} finally {
			loadingMessage.style.display = 'none';
			submitButton.disabled = false;
		}
	});

	function showError(message) {
		errorMessage.innerHTML = '<span class="password-message__dot"></span>' + message;
		errorMessage.style.display = 'flex';
		input.classList.add('error');
		input.value = '';
		input.focus();
		
		// Remove error class after a delay
		setTimeout(() => {
			input.classList.remove('error');
		}, 2000);
	}
</script>