# Encryption password for blog posts
# This password is used to encrypt/decrypt protected blog content
# Replace 'your-secure-password-here' with a strong password
ENCRYPTION_PASSWORD=your-secure-password-here

# API Base URL for encryption API (optional)
# If your API is hosted separately from the frontend, set this URL
# Example: https://api.example.com
# Leave empty to use relative URLs (same domain as frontend)
PUBLIC_API_BASE_URL=